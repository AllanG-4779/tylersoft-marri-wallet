{
  "info": {
    "name": "Mari Wallet API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API collection for Mari Wallet — Payment, Wallet, and User Management services."
  },
  "variable": [
    { "key": "walletBaseUrl", "value": "http://localhost:8082", "type": "string" },
    { "key": "userBaseUrl", "value": "http://localhost:8083", "type": "string" },
    { "key": "paymentBaseUrl", "value": "http://localhost:8081", "type": "string" },
    { "key": "customerId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "User Management",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{userBaseUrl}}/api/v2/users/register",
              "host": ["{{userBaseUrl}}"],
              "path": ["api", "v2", "users", "register"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "data",
                  "value": "{\"firstName\":\"John\",\"lastName\":\"Doe\",\"phoneNumber\":\"+254712345678\",\"email\":\"john.doe@example.com\",\"idType\":\"NATIONAL_ID\",\"idNumber\":\"12345678\"}",
                  "type": "text",
                  "contentType": "application/json"
                },
                { "key": "id_front", "type": "file", "src": [] },
                { "key": "id_back", "type": "file", "src": [], "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{userBaseUrl}}/api/v2/users/verify-otp",
              "host": ["{{userBaseUrl}}"],
              "path": ["api", "v2", "users", "verify-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+254712345678\",\n  \"otp\": \"123456\",\n  \"purpose\": \"REGISTRATION\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{userBaseUrl}}/api/v2/users/resend-otp",
              "host": ["{{userBaseUrl}}"],
              "path": ["api", "v2", "users", "resend-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+254712345678\",\n  \"purpose\": \"REGISTRATION\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Set PIN",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{userBaseUrl}}/api/v2/users/{{customerId}}/set-pin",
              "host": ["{{userBaseUrl}}"],
              "path": ["api", "v2", "users", "{{customerId}}", "set-pin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pin\": \"1234\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Customer",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{userBaseUrl}}/api/v2/users/{{customerId}}",
              "host": ["{{userBaseUrl}}"],
              "path": ["api", "v2", "users", "{{customerId}}"]
            }
          }
        },
        {
          "name": "Upload KYC Documents",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{userBaseUrl}}/api/v2/users/{{customerId}}/kyc/documents",
              "host": ["{{userBaseUrl}}"],
              "path": ["api", "v2", "users", "{{customerId}}", "kyc", "documents"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "idType", "value": "NATIONAL_ID", "type": "text" },
                { "key": "idNumber", "value": "12345678", "type": "text" },
                { "key": "frontImage", "type": "file", "src": [] },
                { "key": "backImage", "type": "file", "src": [], "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get KYC Documents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{userBaseUrl}}/api/v2/users/{{customerId}}/kyc/documents",
              "host": ["{{userBaseUrl}}"],
              "path": ["api", "v2", "users", "{{customerId}}", "kyc", "documents"]
            }
          }
        }
      ]
    },
    {
      "name": "Wallet - Accounts",
      "item": [
        {
          "name": "Open Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/accounts",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "accounts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"currency\": \"KES\",\n    \"accountPrefix\": \"WLT\",\n    \"phoneNumber\": \"+254712345678\",\n    \"accountName\": \"John Doe\",\n    \"openingBalance\": 0.00\n  },\n  \"channelDetails\": {\n    \"channelName\": \"MOBILE\",\n    \"clientId\": \"client-001\",\n    \"hostName\": \"app-host\",\n    \"hostIp\": \"192.168.1.1\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Wallet - Transactions",
      "item": [
        {
          "name": "Fund Transfer (FT)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/transactions/ft",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "transactions", "ft"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"debitAccount\": \"WLT0000001\",\n    \"creditAccount\": \"WLT0000002\",\n    \"amount\": 500.00,\n    \"presentment\": false,\n    \"transactionType\": \"FT\",\n    \"currency\": \"KES\",\n    \"phoneNumber\": \"+254712345678\"\n  },\n  \"channelDetails\": {\n    \"channelName\": \"MOBILE\",\n    \"clientId\": \"client-001\",\n    \"hostName\": \"app-host\",\n    \"hostIp\": \"192.168.1.1\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Card Topup Transaction",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/transactions/card-topup",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "transactions", "card-topup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"debitAccount\": \"CARD_ACCOUNT\",\n    \"creditAccount\": \"WLT0000001\",\n    \"amount\": 1000.00,\n    \"presentment\": false,\n    \"transactionType\": \"CARD_TOPUP\",\n    \"currency\": \"KES\",\n    \"phoneNumber\": \"+254712345678\"\n  },\n  \"channelDetails\": {\n    \"channelName\": \"MOBILE\",\n    \"clientId\": \"client-001\",\n    \"hostName\": \"app-host\",\n    \"hostIp\": \"192.168.1.1\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Wallet - Card Topup",
      "item": [
        {
          "name": "Initiate Card Topup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/topup/card/initiate",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "topup", "card", "initiate"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"creditAccount\": \"WLT0000001\",\n    \"amount\": 1000.00,\n    \"currency\": \"KES\",\n    \"phoneNumber\": \"+254712345678\",\n    \"card\": {\n      \"pan\": \"4111111111111111\",\n      \"cvv\": \"123\",\n      \"expiry\": \"12/26\"\n    }\n  },\n  \"channelDetails\": {\n    \"channelName\": \"MOBILE\",\n    \"clientId\": \"client-001\",\n    \"hostName\": \"app-host\",\n    \"hostIp\": \"192.168.1.1\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Card Topup Callback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/topup/card/callback",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "topup", "card", "callback"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"esbRef\": \"ESB-20240101-001\",\n    \"responseCode\": \"00\",\n    \"responseMessage\": \"Approved\",\n    \"receiptNumber\": \"RCP123456\"\n  },\n  \"channelDetails\": {\n    \"channelName\": \"MOBILE\",\n    \"clientId\": \"client-001\",\n    \"hostName\": \"app-host\",\n    \"hostIp\": \"192.168.1.1\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Wallet - Config",
      "item": [
        {
          "name": "Create Service Config",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/config/services",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "config", "services"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"serviceId\": 1,\n    \"externalServiceId\": \"EXT-001\",\n    \"channelId\": 1,\n    \"serviceCode\": \"FT\",\n    \"isExternal\": false,\n    \"accountId\": 1001,\n    \"senderNarration\": \"Transfer from {{account}}\",\n    \"receiverNarration\": \"Transfer to {{account}}\",\n    \"dailyLimit\": 100000.00,\n    \"weeklyLimit\": 500000.00,\n    \"monthlyLimit\": 2000000.00,\n    \"description\": \"Fund Transfer Service\",\n    \"createdBy\": \"admin\"\n  },\n  \"channelDetails\": {\n    \"channelName\": \"ADMIN\",\n    \"clientId\": \"admin-001\",\n    \"hostName\": \"admin-host\",\n    \"hostIp\": \"192.168.1.1\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get All Service Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/config/services",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "config", "services"]
            }
          }
        },
        {
          "name": "Get Service Config by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/config/services/1",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "config", "services", "1"]
            }
          }
        },
        {
          "name": "Get Service Config by Code",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/config/services/by-code/FT",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "config", "services", "by-code", "FT"]
            }
          }
        },
        {
          "name": "Create Charge Config",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/config/charges",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "config", "charges"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"serviceManagementId\": 1,\n    \"minAmount\": 0.00,\n    \"maxAmount\": 10000.00,\n    \"chargeValue\": 30.00,\n    \"valueType\": \"FLAT\",\n    \"chargeType\": \"SENDER\",\n    \"accountId\": 2001,\n    \"senderNarration\": \"Charge for FT\",\n    \"receiverNarration\": \"Charge credit\",\n    \"createdBy\": \"admin\"\n  },\n  \"channelDetails\": {\n    \"channelName\": \"ADMIN\",\n    \"clientId\": \"admin-001\",\n    \"hostName\": \"admin-host\",\n    \"hostIp\": \"192.168.1.1\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Charges by Service",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/config/charges/service/1",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "config", "charges", "service", "1"]
            }
          }
        },
        {
          "name": "Get Charge by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{walletBaseUrl}}/api/v2/config/charges/1",
              "host": ["{{walletBaseUrl}}"],
              "path": ["api", "v2", "config", "charges", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Payment - Third Party",
      "item": [
        {
          "name": "Send SMS",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{paymentBaseUrl}}/api/v1/third-party/send-sms/+254712345678/Hello%20World",
              "host": ["{{paymentBaseUrl}}"],
              "path": ["api", "v1", "third-party", "send-sms", "+254712345678", "Hello%20World"]
            }
          }
        }
      ]
    }
  ]
}
